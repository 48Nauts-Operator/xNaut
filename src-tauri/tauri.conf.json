{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xNAUT",
  "version": "1.2.0",
  "identifier": "com.nautcode.xnaut",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://tauri.localhost",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "xNAUT - AI-Powered Terminal",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "transparent": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "capabilities": ["default"]
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "",
    "category": "DeveloperTool",
    "shortDescription": "AI-Powered Native Terminal",
    "longDescription": "XNAUT is a modern, AI-enhanced native terminal with advanced features for developers"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}

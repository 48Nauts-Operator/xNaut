{
  "name": "xnaut-frontend",
  "private": true,
  "scripts": {
    "build:loops": "esbuild frontend/loops-editor-entry.js --bundle --format=iife --global-name=XnautRete --platform=browser --target=safari15 --alias:lit/decorators=lit/decorators.js --alias:lit/directives/style-map=lit/directives/style-map.js --outfile=src/js/vendor/loops-editor.bundle.js",
    "build": "npm run build:loops"
  },
  "dependencies": {
    "lit": "3.3.3",
    "rete": "2.0.6",
    "rete-area-plugin": "2.3.2",
    "rete-connection-plugin": "2.0.5",
    "rete-lit-plugin": "2.0.3"
  },
  "devDependencies": {
    "esbuild": "0.28.1"
  }
}
